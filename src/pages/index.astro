---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Obscribe — End-to-End Encrypted Notebooks | Private Note-Taking"
  description="Write privately with Obscribe. End-to-end encrypted notebooks powered by AES-256-GCM. Open source, self-hostable. Your encryption key never leaves your device."
  canonicalUrl="https://obscribe.com/"
  ogUrl="https://obscribe.com/"
  ogTitle="Obscribe — End-to-End Encrypted Notebooks"
  ogDescription="Write privately. End-to-end encrypted notebooks powered by AES-256-GCM. Open source and self-hostable."
>

  <!-- Structured Data -->
  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Obscribe",
    "description": "End-to-end encrypted notebook platform. Open source, self-hostable.",
    "url": "https://obscribe.com",
    "applicationCategory": "ProductivityApplication",
    "operatingSystem": "Web",
    "offers": [
      {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD",
        "description": "Free tier"
      },
      {
        "@type": "Offer",
        "price": "5.00",
        "priceCurrency": "USD",
        "description": "Pro tier - monthly"
      }
    ],
    "author": {
      "@type": "Organization",
      "name": "Obscribe"
    }
  }
  </script>

  <!-- ============ NAV ============ -->
  <nav class="fixed top-0 left-0 right-0 z-50 border-b border-border/50 bg-base/80 backdrop-blur-xl">
    <div class="mx-auto max-w-6xl px-6 py-4 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5 group">
        <div class="w-8 h-8 rounded-lg bg-teal/10 border border-teal/20 flex items-center justify-center group-hover:bg-teal/15 transition-colors">
          <span class="text-teal font-extrabold text-sm">O</span>
        </div>
        <span class="text-text font-semibold text-lg tracking-tight">Obscribe</span>
      </a>
      <div class="flex items-center gap-6">
        <a href="#features" class="text-text-muted hover:text-text text-sm transition-colors hidden sm:block">Features</a>
        <a href="#pricing" class="text-text-muted hover:text-text text-sm transition-colors hidden sm:block">Pricing</a>
        <a href="https://github.com/obscribe" target="_blank" class="text-text-muted hover:text-text text-sm transition-colors hidden sm:block">GitHub</a>
        <a href="#" class="bg-teal hover:bg-teal-light text-base font-medium text-sm px-4 py-2 rounded-lg transition-colors">
          Get Started
        </a>
      </div>
    </div>
  </nav>

  <!-- ============ HERO ============ -->
  <section class="relative min-h-screen flex items-center justify-center grid-bg overflow-hidden">
    <!-- Gradient orbs -->
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-teal/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-teal/3 rounded-full blur-3xl"></div>

    <div class="relative z-10 mx-auto max-w-4xl px-6 text-center pt-24"
         x-data
         x-intersect:enter="$el.classList.add('visible')"
         class:list={["fade-up"]}>

      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-border bg-surface/50 mb-8">
        <span class="w-2 h-2 rounded-full bg-teal animate-pulse"></span>
        <span class="text-text-muted text-xs font-medium tracking-wide uppercase">End-to-end encrypted</span>
      </div>

      <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-extrabold tracking-tight leading-[1.05] mb-6">
        Your words.<br />
        <span class="text-teal">Your vault.</span>
      </h1>

      <p class="text-text-muted text-lg sm:text-xl max-w-2xl mx-auto mb-10 leading-relaxed">
        End-to-end encrypted notebooks powered by AES-256-GCM.
        <span class="text-text">Your encryption key never leaves your device.</span>
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="#"
           class="w-full sm:w-auto bg-teal hover:bg-teal-light text-base font-semibold px-8 py-3.5 rounded-xl transition-all hover:shadow-lg hover:shadow-teal/20 text-center">
          Get Started Free
        </a>
        <a href="#" target="_blank"
           class="w-full sm:w-auto border border-border hover:border-border-light text-text-muted hover:text-text font-medium px-8 py-3.5 rounded-xl transition-all flex items-center justify-center gap-2">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          View on GitHub
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-5 h-5 text-text-dim" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </section>

  <!-- ============ FEATURES ============ -->
  <section id="features" class="py-24 sm:py-32">
    <div class="mx-auto max-w-6xl px-6">
      <div class="text-center mb-16"
           x-data x-intersect:enter="$el.classList.add('visible')" class:list={["fade-up"]}>
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">Built for privacy.<br class="sm:hidden" /> Designed for you.</h2>
        <p class="text-text-muted text-lg max-w-xl mx-auto">Every feature exists to keep your writing private, organized, and beautiful.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          { emoji: "🔐", title: "Zero-Knowledge Encryption", desc: "Your notes are encrypted with AES-256-GCM before they leave your browser. We store encrypted data — not plaintext. Your encryption key is derived from your password and never sent to our servers." },
          { emoji: "📒", title: "Organized Notebooks", desc: "Separate notebooks for work, personal, projects. Each one is its own world." },
          { emoji: "🔍", title: "Instant Search", desc: "Find anything in milliseconds. By keyword, date, or tag." },
          { emoji: "🎨", title: "Beautiful Themes", desc: "Dark, light, or something in between. Make it yours." },
          { emoji: "💣", title: "Self-Destructing Notebooks", desc: "Set a timer. When it expires, everything is gone. Forever." },
          { emoji: "🌐", title: "Open Source", desc: "Every line of code is public under AGPLv3. Audit our encryption implementation, verify our claims, or self-host for complete control." },
        ].map((feature, i) => (
          <div
            x-data x-intersect:enter="setTimeout(() => $el.classList.add('visible'), {i} * 100)"
            class:list={["fade-up", "group rounded-2xl border border-border bg-surface/50 p-6 hover:border-teal/20 hover:bg-surface-hover transition-all duration-300"]}>
            <div class="text-3xl mb-4">{feature.emoji}</div>
            <h3 class="text-lg font-semibold mb-2 group-hover:text-teal transition-colors">{feature.title}</h3>
            <p class="text-text-muted text-sm leading-relaxed">{feature.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ HOW IT WORKS ============ -->
  <section class="py-24 sm:py-32 border-t border-border/50">
    <div class="mx-auto max-w-4xl px-6">
      <div class="text-center mb-16"
           x-data x-intersect:enter="$el.classList.add('visible')" class:list={["fade-up"]}>
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">Three steps to privacy.</h2>
        <p class="text-text-muted text-lg">No complicated setup. No key management headaches.</p>
      </div>

      <div class="space-y-12 sm:space-y-0 sm:grid sm:grid-cols-3 sm:gap-8">
        {[
          { step: "01", title: "Sign up with your email", desc: "Create your account in seconds. No phone number. No social login required." },
          { step: "02", title: "Your key is derived", desc: "Your encryption key is derived from your password using PBKDF2 with 600,000 iterations. This key never leaves your device." },
          { step: "03", title: "Start writing", desc: "When you write, your notes are encrypted with AES-256-GCM in your browser before being sent to our servers. We store ciphertext — we don't have the ability to read your content." },
        ].map((item, i) => (
          <div
            x-data x-intersect:enter={`setTimeout(() => $el.classList.add('visible'), ${i * 150})`}
            class:list={["fade-up", "text-center"]}>
            <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-teal/10 border border-teal/20 mb-5">
              <span class="text-teal font-bold text-sm">{item.step}</span>
            </div>
            <h3 class="text-lg font-semibold mb-2">{item.title}</h3>
            <p class="text-text-muted text-sm leading-relaxed max-w-xs mx-auto">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ PRICING ============ -->
  <section id="pricing" class="py-24 sm:py-32 border-t border-border/50">
    <div class="mx-auto max-w-5xl px-6">
      <div class="text-center mb-16"
           x-data x-intersect:enter="$el.classList.add('visible')" class:list={["fade-up"]}>
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">Simple pricing. No surprises.</h2>
        <p class="text-text-muted text-lg">Start free. Upgrade when you need more.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-3xl mx-auto">
        <!-- Free -->
        <div x-data x-intersect:enter="$el.classList.add('visible')" class:list={["fade-up",
          "rounded-2xl border border-border bg-surface/50 p-8"]}>
          <div class="mb-6">
            <h3 class="text-lg font-semibold mb-1">Free</h3>
            <p class="text-text-muted text-sm">For getting started</p>
          </div>
          <div class="mb-6">
            <span class="text-4xl font-extrabold">$0</span>
            <span class="text-text-muted text-sm ml-1">/ forever</span>
          </div>
          <ul class="space-y-3 mb-8">
            {["1 notebook", "100 pages", "Dark + light themes", "Instant search", "End-to-end encryption (AES-256-GCM)"].map(f => (
              <li class="flex items-center gap-3 text-sm text-text-muted">
                <svg class="w-4 h-4 text-teal shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {f}
              </li>
            ))}
          </ul>
          <a href="#"
             class="block w-full text-center border border-border hover:border-border-light text-text font-medium py-3 rounded-xl transition-colors">
            Get Started
          </a>
        </div>

        <!-- Pro -->
        <div x-data x-intersect:enter="setTimeout(() => $el.classList.add('visible'), 100)" class:list={["fade-up",
          "rounded-2xl border border-teal/30 bg-surface/50 p-8 relative glow-teal"]}>
          <div class="absolute -top-3 left-6">
            <span class="bg-teal text-base text-xs font-bold px-3 py-1 rounded-full">Popular</span>
          </div>
          <div class="mb-6">
            <h3 class="text-lg font-semibold mb-1">Pro</h3>
            <p class="text-text-muted text-sm">For serious writers</p>
          </div>
          <div class="mb-6">
            <span class="text-4xl font-extrabold">$5</span>
            <span class="text-text-muted text-sm ml-1">/ month</span>
            <p class="text-text-dim text-xs mt-1">or $48/year (save 20%)</p>
          </div>
          <ul class="space-y-3 mb-8">
            {["Unlimited notebooks", "Unlimited pages", "All themes", "Temporary notebooks", "File attachments", "Version history", "Priority support"].map(f => (
              <li class="flex items-center gap-3 text-sm text-text-muted">
                <svg class="w-4 h-4 text-teal shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {f}
              </li>
            ))}
          </ul>
          <a href="#"
             class="block w-full text-center bg-teal hover:bg-teal-light text-base font-semibold py-3 rounded-xl transition-all hover:shadow-lg hover:shadow-teal/20">
            Start Pro Trial
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ OPEN SOURCE ============ -->
  <section class="py-24 sm:py-32 border-t border-border/50">
    <div class="mx-auto max-w-4xl px-6 text-center"
         x-data x-intersect:enter="$el.classList.add('visible')" class:list={["fade-up"]}>

      <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-teal/10 border border-teal/20 mb-8">
        <svg class="w-7 h-7 text-teal" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
      </div>

      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">
        Don't take our word for it.<br />
        <span class="text-teal">Read the code.</span>
      </h2>

      <p class="text-text-muted text-lg max-w-xl mx-auto mb-8 leading-relaxed">
        Obscribe is fully open source under AGPLv3. Our encryption implementation is transparent and auditable. Self-host if you want complete control over your data.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-2xl mx-auto mb-10">
        {[
          { label: "License", value: "AGPLv3" },
          { label: "Self-hostable", value: "Yes" },
          { label: "Warrant canary", value: "Active" },
        ].map(item => (
          <div class="rounded-xl border border-border bg-surface/50 p-4">
            <p class="text-text-dim text-xs uppercase tracking-wide mb-1">{item.label}</p>
            <p class="text-text font-semibold">{item.value}</p>
          </div>
        ))}
      </div>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="#" target="_blank"
           class="bg-teal hover:bg-teal-light text-base font-semibold px-8 py-3.5 rounded-xl transition-all hover:shadow-lg hover:shadow-teal/20 flex items-center gap-2">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          View Source Code
        </a>

      </div>
    </div>
  </section>

  <!-- ============ FINAL CTA ============ -->
  <section class="py-24 sm:py-32 border-t border-border/50 relative overflow-hidden">
    <div class="absolute inset-0 grid-bg"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-teal/5 rounded-full blur-3xl"></div>

    <div class="relative z-10 mx-auto max-w-3xl px-6 text-center"
         x-data x-intersect:enter="$el.classList.add('visible')" class:list={["fade-up"]}>
      <h2 class="text-3xl sm:text-5xl font-extrabold tracking-tight mb-6">
        Ready to write privately?
      </h2>
      <p class="text-text-muted text-lg mb-10 max-w-lg mx-auto">
        Join thousands of people who use Obscribe to keep their writing private.
      </p>
      <a href="#"
         class="inline-block bg-teal hover:bg-teal-light text-base font-semibold px-10 py-4 rounded-xl transition-all hover:shadow-lg hover:shadow-teal/20 text-lg">
        Start Writing — It's Free
      </a>
    </div>
  </section>

  <!-- ============ FOOTER ============ -->
  <footer class="border-t border-border/50 py-12">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-8 mb-12">
        <div>
          <h4 class="text-text font-semibold text-sm mb-4">Product</h4>
          <ul class="space-y-2.5">
            <li><a href="#" class="text-text-muted hover:text-text text-sm transition-colors">App</a></li>
            <li><a href="#features" class="text-text-muted hover:text-text text-sm transition-colors">Features</a></li>
            <li><a href="#pricing" class="text-text-muted hover:text-text text-sm transition-colors">Pricing</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-text font-semibold text-sm mb-4">Resources</h4>
          <ul class="space-y-2.5">
            <li><a href="#" class="text-text-muted hover:text-text text-sm transition-colors">Documentation <span class="text-text-dim text-xs">(soon)</span></a></li>

            <li><a href="#" class="text-text-muted hover:text-text text-sm transition-colors">Self-hosting guide <span class="text-text-dim text-xs">(soon)</span></a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-text font-semibold text-sm mb-4">Legal</h4>
          <ul class="space-y-2.5">
            <li><a href="/privacy" class="text-text-muted hover:text-text text-sm transition-colors">Privacy policy</a></li>
            <li><a href="/terms" class="text-text-muted hover:text-text text-sm transition-colors">Terms of service</a></li>
            <li><a href="#" class="text-text-muted hover:text-text text-sm transition-colors">Warrant canary</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-text font-semibold text-sm mb-4">Open Source</h4>
          <ul class="space-y-2.5">
            <li><a href="https://github.com/obscribe" target="_blank" class="text-text-muted hover:text-text text-sm transition-colors">GitHub</a></li>
            <li><a href="https://github.com/obscribe/backend/blob/main/LICENSE" target="_blank" class="text-text-muted hover:text-text text-sm transition-colors">AGPLv3 License</a></li>
            <li><a href="https://github.com/obscribe" target="_blank" class="text-text-muted hover:text-text text-sm transition-colors">Contributing</a></li>
          </ul>
        </div>
      </div>

      <div class="border-t border-border/50 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-2.5">
          <div class="w-6 h-6 rounded-md bg-teal/10 border border-teal/20 flex items-center justify-center">
            <span class="text-teal font-extrabold text-[10px]">O</span>
          </div>
          <span class="text-text-dim text-sm">© 2026 Obscribe. Open source under AGPLv3.</span>
        </div>
        <div class="flex items-center gap-4">
          <a href="#" target="_blank" class="text-text-dim hover:text-text-muted transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </a>
        </div>
      </div>
    </div>
  </footer>

  <!-- Development Banner Modal -->
