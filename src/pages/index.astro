      <!-- Logo -->
      <div class="mx-auto mb-5 flex h-16 w-16 items-center justify-center rounded-2xl border border-teal/20 bg-teal/10">
        <span class="text-2xl font-extrabold text-teal">O</span>
      </div>
      
      <!-- Badge -->
      <div class="mx-auto mb-4 inline-flex items-center gap-2 rounded-full border border-amber-500/30 bg-amber-500/10 px-4 py-1.5">
        <span class="h-2 w-2 rounded-full bg-amber-400 animate-pulse"></span>
        <span class="text-xs font-semibold uppercase tracking-wider text-amber-400">In Development</span>
      </div>
      
      <h2 class="mb-3 text-2xl font-bold tracking-tight text-text">We're building something private.</h2>
      
      <p class="mb-4 text-sm leading-relaxed text-text-muted">
        Obscribe is an end-to-end encrypted notebook platform — currently in active development. 
        We're working hard to bring you a secure, open-source way to write privately.
      </p>
      
      <div class="mb-6 rounded-xl border border-border bg-base/50 p-4 text-left">
        <p class="mb-2 text-xs font-semibold uppercase tracking-wider text-text-dim">Coming soon</p>
        <ul class="space-y-2 text-sm text-text-muted">
          <li class="flex items-center gap-2">
            <span class="text-teal">✓</span> AES-256-GCM end-to-end encryption
          </li>
          <li class="flex items-center gap-2">
            <span class="text-teal">✓</span> Open source on GitHub (AGPLv3)
          </li>
          <li class="flex items-center gap-2">
            <span class="text-teal">✓</span> Self-hostable
          </li>
          <li class="flex items-center gap-2">
            <span class="text-teal">✓</span> Free tier with Pro upgrade option
          </li>
        </ul>
      </div>
      
      <button @click="show = false" class="w-full rounded-xl bg-teal px-6 py-3 text-sm font-semibold text-base transition-all hover:bg-teal-light hover:shadow-lg hover:shadow-teal/20">
        Explore the Site →
      </button>
      
      <p class="mt-4 text-xs text-text-dim">
        Follow our progress — we'll announce when we go live.
      </p>
    </div>
  </div>

</Layout>
